# Web app — copy to .env.local for local overrides.
# Base URL of the Calypr API (server-side fetch from the dashboard).
CALYPR_API_URL=http://localhost:8000

# Shared secret this proxy presents to the API, so the API can trust the user id it forwards.
# **Must match `CALYPR_INTERNAL_KEY` in the repo-root `.env`** — the API loads that file, Next
# loads this one, and a mismatch 401s while omitting it here silently drops every request onto
# the shared dev workspace. Not a model API key.
#
# Leave unset for ordinary local work; set it (both files) to exercise tenant scoping and the
# billing gates, which no-op without it.
# CALYPR_INTERNAL_KEY=

# Better Auth (optional). Leave BETTER_AUTH_SECRET unset to use the keyless dev sign-in
# (local + CI). Set all of these to switch the whole app to Better Auth (GitHub OAuth) —
# no code changes needed. Then run: npx @better-auth/cli migrate (creates the auth tables).
# BETTER_AUTH_SECRET=        # openssl rand -base64 32
# BETTER_AUTH_URL=http://localhost:3100
# DATABASE_URL=postgresql://calypr:calypr@localhost:5432/calypr
# GitHub OAuth app → callback URL: ${BETTER_AUTH_URL}/api/auth/callback/github
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
