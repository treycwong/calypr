# Calypr API — copy to .env for local overrides (defaults work for local dev).
CALYPR_ENVIRONMENT=development
CALYPR_CORS_ORIGINS=["http://localhost:3000"]
CALYPR_DATABASE_URL=postgresql+psycopg://calypr:calypr@localhost:5432/calypr
CALYPR_AUTH_PROVIDER=dev

# --- Tenant scoping / enforcement ----------------------------------------------------------
# Shared secret the Next proxy presents so the API can believe its `X-Calypr-User-Id` header.
# NOT a model API key — it never pays for a token. Any hard-to-guess string will do.
#
# **Must match `CALYPR_INTERNAL_KEY` in `apps/web/.env.local`.** The two are read by different
# processes from different files, and half-setting it fails quietly rather than loudly: `/runs`
# falls back to the shared dev workspace while `/assist` 401s.
#
# Unset (the default) ⇒ every request resolves to the shared dev workspace and **the billing
# gates no-op** — `credits.check_can_run` and `run_access.check_run_gates` both return on their
# first line. That's what keeps local dev, CI and e2e unmetered, but it also means you cannot
# exercise Free's BYO-key rule or the credit ceiling without setting this.
#
# Note the dev workspace is exempt even when this *is* set, so testing the gates also needs a
# signed-in user: the dev session cookie (`calypr_session`) holds the user id as its value.
# CALYPR_INTERNAL_KEY=

# Image node (gpt-image-2): OPENAI_API_KEY (repo-root .env) powers generation; the fake model
# is keyless. BLOB_READ_WRITE_TOKEN (a Vercel Blob store's read-write token) stores generated
# images at a durable URL — without it, the node degrades to an inline data: URI.
# BLOB_READ_WRITE_TOKEN=
# VERCEL_BLOB_API_VERSION=10  # only if Vercel bumps the blob upload API version

# --- Billing (Stripe) ---------------------------------------------------------------------
# All three unset ⇒ /billing/* returns 503 and the checkout page captures intent instead of
# taking a card. That's the intended "not launched yet" state, not a misconfiguration.
# Names are Stripe's own conventions (not CALYPR_-prefixed) so a key copied from the Stripe
# dashboard has an obvious home.
#
# Test mode first: test and live have entirely separate keys, endpoints and signing secrets.
#   STRIPE_SECRET_KEY      Developers → API keys           (sk_test_… / sk_live_…)
#   STRIPE_WEBHOOK_SECRET  the signing secret shown when you create the webhook endpoint (whsec_…)
#   STRIPE_PLUS_PRICE_ID   the $20/mo recurring price on the Plus product (price_…)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PLUS_PRICE_ID=
